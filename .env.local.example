# Copy this file to .env.local (which is gitignored) and fill in your key.
# Never commit real API keys.

# Required for "Ask AI for nuance" / "Ask AI to explain" to work (see
# src/lib/ai/openai.ts). Without it, those buttons show a friendly
# "AI is not configured" message — the rest of the app works normally.
# Get a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Optional — defaults to gpt-4o-mini (cheap, fast, good enough for this app's
# short texts). Any OpenAI chat-completions model that supports JSON mode works.
OPENAI_MODEL=gpt-4o-mini

# Required in production for Vercel Cron to warm the RSS pool safely.
# Set the same value in Vercel Project Settings -> Environment Variables.
CRON_SECRET=

# Optional: lets RSS article links survive a new tab/app restart (see
# src/lib/rss/rssTextStore.ts). Without these, the app works exactly as
# before — RSS texts just live only in the current tab's sessionStorage.
# Add a Redis/Upstash integration from the Vercel Marketplace and it'll set
# one of these two pairs for you automatically:
KV_REST_API_URL=
KV_REST_API_TOKEN=
# or, if provisioned directly via Upstash:
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional: cross-device sync (saved words, known words, goals, settings,
# reading history) via Supabase auth + a synced `user_data` table. Without
# these, the app works exactly as before — everything stays local to this
# browser, and Settings simply doesn't show a "Sync across devices" card.
# See "Cross-device sync" in the README for the exact setup steps (create a
# project, run the SQL, enable email auth, copy these two values in).
# These two are safe to expose to the browser (hence NEXT_PUBLIC_) — the
# anon key only grants what the SQL's row-level-security policies allow.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional: server-side Supabase service role for validation analytics,
# Android beta interest, feedback, research prompts, and the admin dashboard.
# Never expose this value to the browser. Set only in local .env / Vercel
# server environment variables.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Optional: product validation feature flags. Production analytics send only
# when NEXT_PUBLIC_ANALYTICS_ENABLED is true and the deployment environment is
# production, unless non-production inclusion is explicitly enabled.
NEXT_PUBLIC_ANALYTICS_ENABLED=true
NEXT_PUBLIC_ANALYTICS_INCLUDE_NON_PRODUCTION=false
NEXT_PUBLIC_ANDROID_BETA_CTA_ENABLED=true
NEXT_PUBLIC_FEEDBACK_ENABLED=true
NEXT_PUBLIC_POST_SESSION_PROMPTS_ENABLED=true
NEXT_PUBLIC_PRODUCT_DISAPPEARANCE_SURVEY_ENABLED=true
NEXT_PUBLIC_ADMIN_DASHBOARD_ENABLED=true
NEXT_PUBLIC_BETA_BANNER_ENABLED=true
NEXT_PUBLIC_DEPLOYMENT_ENV=
NEXT_PUBLIC_APP_VERSION=
NEXT_PUBLIC_PRODUCTION_DOMAIN=https://liree.vercel.app

# Required to read the protected /admin/validation data route. The dashboard
# asks for this token and sends it as Authorization: Bearer <token>.
VALIDATION_ADMIN_TOKEN=

# Optional: confirmation email for Android beta registrations, sent via
# Resend's REST API with no app dependency. Leave disabled to skip email.
NEXT_PUBLIC_EMAIL_CONFIRMATION_ENABLED=false
RESEND_API_KEY=
BETA_CONFIRMATION_FROM=
